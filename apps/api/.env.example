# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# --- Auth (dev-mode HS256 signer; replace with Clerk JWKS in staging+) ---
JWT_SECRET=dev-only-do-not-use-in-production-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Redis (optional in dev) ---
REDIS_URL=redis://localhost:6379

# --- S3 / R2 (optional in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_FILES=books-files
S3_BUCKET_COVERS=books-covers
S3_BUCKET_EXPORTS=exports

# --- Observability ---
SENTRY_DSN=
