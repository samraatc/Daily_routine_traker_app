# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
PUBLIC_API_URL=http://localhost:4000/api/v1

# --- Database (Postgres for relational data) ---
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# --- File storage ---
# 'mongodb' uses GridFS (default — what the deploy guide uses).
# 's3' switches to S3-compatible (R2, MinIO, AWS S3).
STORAGE_DRIVER=mongodb

# MongoDB (used when STORAGE_DRIVER=mongodb)
MONGODB_URL=mongodb://app:app@localhost:27017/app?authSource=admin
MONGODB_BUCKET_FILES=books_files
MONGODB_BUCKET_COVERS=books_covers

# S3-compatible (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_FILES=books-files
S3_BUCKET_COVERS=books-covers
S3_BUCKET_EXPORTS=exports

# --- Auth (dev-mode HS256; replace with Clerk JWKS in staging+) ---
JWT_SECRET=dev-only-do-not-use-in-production-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Redis (optional in dev; required for BullMQ in Phase 3) ---
REDIS_URL=redis://localhost:6379

# --- Observability ---
SENTRY_DSN=
